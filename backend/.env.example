# Optional: Kostenlosen Groq API-Key eintragen (https://console.groq.com)
GROQ_API_KEY=dein-groq-api-key-hier

# Telegram-Bot Integration (optional)
# 1) Bot bei @BotFather erstellen und Token eintragen
# 2) Starkes Secret setzen (für Webhook-Pfad + Header-Validierung)
# 3) Öffentliche HTTPS-URL auf dein Backend setzen
# 4) Optional: erlaubte Chat-IDs komma-separiert einschränken
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_ALLOWED_CHAT_IDS=
# webhook (prod mit HTTPS-URL) oder polling (lokal ohne öffentliche URL)
TELEGRAM_MODE=webhook

# KPI Auto-Reporting (2C)
KPI_AUTOREPORT_ENABLED=true
KPI_AUTOREPORT_INTERVAL_MINUTES=60
KPI_REPORT_WINDOW_DAYS=30

# Optional: Host-Ports ändern, falls 5000/5173 bereits belegt sind
# BACKEND_PORT=5001
# FRONTEND_PORT=5174
